# Service Ports 
ROUTER_PORT=8001
VISION_PORT=8002
KNOWLEDGE_PORT=8003
ORCHESTRATOR_PORT=8000

# Model Paths
BUSI_CHECKPOINT=models/checkpoints/mtl_effnet_fc_conv.pt
THYROID_CHECKPOINT=models/checkpoints/mtl_effnet_fc_conv_thyroid.pt
ROUTER_CHECKPOINT=models/checkpoints/router_effnet_b0.pth

# Router (Layer 1) 
OOD_THRESHOLD=0.06
# Chỉ set true khi cố ý demo dev/local mà chưa có router checkpoint đã train.
# Khi true, orchestrator KHÔNG chặn pipeline dù router đang chạy random weights
ALLOW_DEGRADED_ROUTER=false

# Knowledge (Layer 3) 
# Ngưỡng confidence để gắn cảnh báo "có thể chưa calibrate" vào report.
CONFIDENCE_CALIBRATION_THRESHOLD=0.999

# Module Registry (Layer 4) 
# Nguồn duy nhất cho endpoint path + enabled/disabled của mỗi module.
MODULE_REGISTRY_PATH=module_registry.yaml

# LLM Backend 
# Options: ollama | google | mock
LLM_BACKEND=google

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava-med

GOOGLE_API_KEY=
GOOGLE_MODEL=

# RAG 
FAISS_INDEX_PATH=services/orchestrator/rag/vectordb/index.faiss
RAG_DOCS_DIR=services/orchestrator/rag/docs
RAG_VECTORDB_DIR=services/orchestrator/rag/vectordb

