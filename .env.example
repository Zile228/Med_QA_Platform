# Service Ports 
ROUTER_PORT=8001
VISION_PORT=8002
KNOWLEDGE_PORT=8003
ORCHESTRATOR_PORT=8000

# Model Paths
BUSI_CHECKPOINT=models/checkpoints/mtl_effnet_fc_conv_breast.pt
THYROID_CHECKPOINT=models/checkpoints/mtl_effnet_fc_conv_thyroid.pt
ROUTER_CHECKPOINT=models/checkpoints/router_effnet_b0.pth

# Router (Layer 1) 
OOD_THRESHOLD=0.6
# Only set to true when intentionally demoing dev/local without a trained
# router checkpoint yet. When true, the orchestrator does NOT block the
# pipeline even though the router is running with random weights.
ALLOW_DEGRADED_ROUTER=false
DISABLE_XAI=true

# Knowledge (Layer 3) 
# Confidence threshold for attaching a "may not be calibrated" warning to the report.
CONFIDENCE_CALIBRATION_THRESHOLD=0.999

# Module Registry (Layer 4) 
# Single source of truth for the endpoint path + enabled/disabled state of each module.
MODULE_REGISTRY_PATH=module_registry.yaml

# LLM Backend 
# Options: ollama | google | openai | remote | local_hf | mock
LLM_BACKEND=openai

# "ollama" is the service name in docker-compose.yml -- localhost would
# point at the orchestrator container itself, not the sibling ollama service.
OLLAMA_BASE_URL=http://ollama:11434
# phi4-mini: MIT-licensed, text-only, CPU-first pick (see README Setup section).
# If quality/throughput on CPU is insufficient, switch to qwen2.5:7b (Apache 2.0).
OLLAMA_MODEL=phi4-mini

GOOGLE_API_KEY=
GOOGLE_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# RAGAS eval scripts (eval/eval_ragas.py, eval/generate_ragas_testset.py) read
# this separately to pick the LLM used for scoring/testset generation.
# Defaults to LLM_BACKEND above if unset. Only "google" or "openai" accepted.
# RAGAS_LLM_BACKEND=openai

# Fine-tuned model deployed on a rented pod (RunPod, Vast.ai, Modal...)
# LLM_BACKEND=remote
# REMOTE_INFERENCE_URL=https://xxxx.runpod.net   <- pod URL after deploy (no /v1 suffix, client appends it)
# REMOTE_MODEL_NAME=                              <- model name vLLM was started with (the value passed to "vllm serve <model>")
# REMOTE_INFERENCE_TOKEN=                        <- must match vLLM's VLLM_API_KEY on the pod; leave empty if the pod does not require auth
# REMOTE_TIMEOUT=30

# Local fine-tuned model -- slow on CPU, eval only
# LLM_BACKEND=local_hf
# HF_MODEL_PATH=/path/to/cot_reasoner_qwen_merged

# RAG 
FAISS_INDEX_PATH=services/orchestrator/rag/vectordb/index.faiss
RAG_DOCS_DIR=services/orchestrator/rag/docs
RAG_VECTORDB_DIR=services/orchestrator/rag/vectordb

# Monitoring (Grafana) 
# Must be set. There is no default value - docker compose will fail to
# start Grafana if this variable is missing.
GRAFANA_PASSWORD=

